# Server-side AI Engine selection.
# auto uses OPENAI_API_KEY first when it exists, otherwise GEMINI_API_KEY.
AI_ENGINE_PROVIDER=auto

# Put real keys only in .env.local, never in this file.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides.
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-flash-latest
